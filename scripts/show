#!/usr/bin/env bash
# Switch animation on the round display.
# Usage: show <name> | show list | show status
# Examples: show anim3 | show project1 | show default | show radar4

set -euo pipefail

API="${BMW_LOGO_API:-http://127.0.0.1:8080}"
NAME="${1:-list}"

list_gallery() {
  curl -s "${API}/api/gallery" | python3 -c '
import sys, json
items = json.load(sys.stdin)
for i in items:
    mid = i.get("id", "")
    if not mid.startswith("builtin-bmw-"):
        continue
    short = mid.replace("builtin-bmw-", "")
    print("%-12s  %s" % (short, i.get("name", "")))
'
}

resolve_id() {
  local raw="${1,,}"
  raw="${raw%.webm}"; raw="${raw%.mp4}"; raw="${raw%.gif}"
  raw="${raw// /}"; raw="${raw//-/}"

  # Aliases for friendly names
  case "$raw" in
    default) raw="radar4" ;;
  esac

  echo "builtin-bmw-${raw}"
}

if [[ "$NAME" == "list" || "$NAME" == "ls" || -z "$NAME" ]]; then
  list_gallery
  exit 0
fi

if [[ "$NAME" == "status" || "$NAME" == "st" ]]; then
  curl -s "${API}/api/status"
  echo
  exit 0
fi

if [[ "$NAME" == builtin-* ]]; then
  MEDIA_ID="$NAME"
else
  MEDIA_ID="$(resolve_id "$NAME")"
fi

echo "→ ${MEDIA_ID}"
# Do not use curl -f: always print body so errors are visible
RESP="$(curl -s -w "\n%{http_code}" -X POST "${API}/api/display" \
  -H 'Content-Type: application/json' \
  -d "{\"media_id\":\"${MEDIA_ID}\"}")"
BODY="$(printf '%s' "$RESP" | sed '$d')"
CODE="$(printf '%s' "$RESP" | tail -n1)"
echo "$BODY"
if [[ "$CODE" != "200" ]]; then
  echo "HTTP $CODE" >&2
  exit 1
fi
