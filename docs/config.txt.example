# Raspberry Pi OS (Bookworm) — append to /boot/firmware/config.txt
# Round Wisecoco/VIEWE 2.8" 480x480 @ 60Hz via UEDX6911-HDMI V2.0

hdmi_force_hotplug=1
hdmi_group=2
hdmi_mode=87
hdmi_cvt=480 480 60 4 0 0 0
hdmi_drive=2
config_hdmi_boost=7
max_usb_current=1

framebuffer_width=480
framebuffer_height=480
gpu_mem=128

# Fallback if image is offset (uncomment and comment hdmi_cvt block above):
# hdmi_timings=480 1 10 20 50 480 1 10 10 5 0 0 0 60 0 16960000 4
