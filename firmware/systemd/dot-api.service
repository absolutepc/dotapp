[Unit]
Description=Dot HTTP API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/opt/dot
Environment=PYTHONPATH=/opt/dot
ExecStart=/opt/dot/.venv/bin/uvicorn firmware.main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
