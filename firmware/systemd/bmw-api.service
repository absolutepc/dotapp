[Unit]
Description=BMW Logo HTTP API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/opt/bmw-logo
Environment=PYTHONPATH=/opt/bmw-logo
ExecStart=/opt/bmw-logo/.venv/bin/uvicorn firmware.main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
