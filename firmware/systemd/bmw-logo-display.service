[Unit]
Description=BMW Logo HDMI Display Renderer
After=graphical.target bmw-logo-api.service
Wants=graphical.target

[Service]
Type=simple
User=pi
WorkingDirectory=/opt/bmw-logo
Environment=PYTHONPATH=/opt/bmw-logo
Environment=SDL_VIDEODRIVER=kmsdrm
ExecStart=/opt/bmw-logo/.venv/bin/python -m firmware.display.hdmi_renderer
Restart=always
RestartSec=3

[Install]
WantedBy=graphical.target
